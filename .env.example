# Hugging Face token — необходим для pyannote diarization моделей.
# Получить на https://huggingface.co/settings/tokens
# Перед использованием примите условия использования моделей:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_xxxxxxxxxxxxxxxxx

# Модель WhisperX: tiny, base, small, medium, large-v2, large-v3
MODEL=large-v3

# Язык аудио (ru, en, de, fr, и т.д.)
LANGUAGE=ru

# Модель диаризации (разделение по спикерам)
# Нужно принять лицензию на: https://huggingface.co/pyannote/speaker-diarization-3.1
DIARIZE_MODEL=pyannote/speaker-diarization-3.1

# Минимальное и максимальное количество спикеров (оставить пустым для автоопределения)
MIN_SPEAKERS=2
MAX_SPEAKERS=6

# Устройство: cuda (GPU) или cpu
DEVICE=cuda

# Тип вычислений: float16 для GPU, int8 для CPU
COMPUTE_TYPE=float16

# --- CPU fallback (раскомментировать при отсутствии GPU) ---
# DEVICE=cpu
# COMPUTE_TYPE=int8

# ─────────────────────────────────────────────────────────────────────────────
# LLM Summary — OpenAI-compatible endpoint
# Профиль и модель выбираются в UI (страница /settings) и сохраняются в
# output/_settings.json. Значения ниже — fallback на случай чистого старта.
#
# Профили в UI:
#   • OpenAI (online)   → https://api.openai.com/v1     (нужен API ключ — задаётся в UI)
#   • DeepSeek (online) → https://api.deepseek.com/v1   (нужен API ключ — задаётся в UI)
#   • LM Studio (local) → http://localhost:1234/v1      (запустить на хосте)
#   • Ollama (local)    → http://localhost:11434/v1     (`ollama serve` на хосте)
#   • Custom            → свой URL/ключ задаются в UI
# API ключи онлайн-провайдеров вводятся на странице /settings и хранятся в output/_settings.json.
# Контейнер автоматически переписывает localhost → host.docker.internal.
# ─────────────────────────────────────────────────────────────────────────────

LLM_PROVIDER=openai_compatible

# Профиль по умолчанию: openai | deepseek | lmstudio | ollama | custom
LLM_PROFILE=ollama

# API ключ fallback (обычно задаётся в UI). Для LM Studio / Ollama не нужен
LLM_API_KEY=not-required

# Fallback-значения (UI их перекрывает, но они нужны для headless-режима)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:32b

# Размер чанка транскрипта (в символах). ~12000 ≈ 3000 токенов
CHUNK_SIZE_CHARS=12000

# Размер overlap между чанками (в символах, по границам speaker-блоков)
CHUNK_OVERLAP_CHARS=2000

# ───────────────────────────────────────────────────────────────────────────────
# Anonymization — локальная анонимизация PII перед отправкой в онлайн LLM
# Mapping реальные_сущности → токены хранится локально в *_anonymization_map.json
# ───────────────────────────────────────────────────────────────────────────────

# Включить анонимизацию (рекомендуется при использовании онлайн LLM)
ENABLE_ANONYMIZATION=false

# Тонкая настройка (по умолчанию всё включено)
ANONYMIZE_PERSONS=true
ANONYMIZE_COMPANYS=true
ANONYMIZE_LOCATIONS=true
ANONYMIZE_EMAILS=true
ANONYMIZE_PHONES=true
ANONYMIZE_URLS=true
ANONYMIZE_DOMAINS=true
ANONYMIZE_TRANSACTIONS=true

# ─────────────────────────────────────────────────────────────────────────────
# Debug
# ─────────────────────────────────────────────────────────────────────────────

# Сохранять анонимизированный текст чанков в intermediate/*_chunk_NN_anon.txt
# Позволяет убедиться, что PII-сущности корректно заменены перед отправкой в LLM
ANONYMIZE_SAVE_DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Obsidian Vault integration
# ─────────────────────────────────────────────────────────────────────────────
# Полный путь к корню вашего Obsidian Vault на хост-машине.
# Этот путь монтируется в контейнер как /vault.
# По умолчанию — локальная папка ./obsidian_vault (создаётся автоматически).
# Примеры (Windows):  C:/Users/me/Documents/MyVault
# Примеры (Linux):    /home/me/Vaults/Work
OBSIDIAN_VAULT_PATH=./obsidian_vault

# Подпапка внутри Vault, куда складывать обработанные планёрки.
# Полный путь = OBSIDIAN_VAULT_PATH / OBSIDIAN_SUBFOLDER / <Категория> / <дата — название>.md
OBSIDIAN_SUBFOLDER=Meetings

LLM_LOG_THINKING=1

# ─── Стиль итоговой заметки ─────────────────────────────────────────────────
# full     — все разделы (TL;DR, контекст, действия, коуч, карта, статусы,
#            последовательность, бизнес-контекст, решения, блокеры, риски,
#            вопросы, наблюдения). Самый длинный — медленно на локальной LLM.
# compact  — TL;DR + коуч (с процессными наблюдениями внутри) + ключевые
#            решения (top-7) + действия (отфильтрованные) + вопросы (top-5)
#            + объединённая таблица «риски и блокеры» (top-7).
# minimal  — только TL;DR + коуч + действия с владельцем/сроком.
SUMMARY_MODE=compact

# ─── Воронка (watch folder) — авто-обработка ────────────────────────────────
# Файлы, брошенные в папку inbox/, автоматически уходят в обработку и затем
# перемещаются в processed/ (успех) или failed/ (ошибка).
# Категорию можно задать подпапками: inbox/<Категория>/<Подкатегория>/file.mp3
# WATCH_ENABLED            — 1 включить / 0 выключить (по умолчанию 1)
# WATCH_INTERVAL           — период опроса папки, секунды (минимум 2)
# WATCH_DEFAULT_CATEGORY   — категория для файлов в корне inbox/
# WATCH_DEFAULT_SUBCATEGORY— подкатегория для файлов в корне inbox/
# WATCH_LLM                — 1 запускать LLM-анализ для авто-файлов (по умолч. 1)
WATCH_ENABLED=1
WATCH_INTERVAL=5
WATCH_DEFAULT_CATEGORY=Общее
WATCH_DEFAULT_SUBCATEGORY=Без подкатегории
WATCH_LLM=1
