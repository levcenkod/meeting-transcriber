@echo off
chcp 65001 >nul
cd /d "%~dp0"

echo ============================================
echo  Шаг 1/2: git pull
echo ============================================
call "%~dp0pull.bat"
if errorlevel 1 (
    echo.
    echo [ОШИБКА] pull.bat завершился с ошибкой. Прерываю.
    pause
    exit /b 1
)

echo.
echo ============================================
echo  Шаг 2/2: пересборка контейнера
echo ============================================
call "%~dp0update.bat"
