# Все текстовые файлы — LF
* text=auto eol=lf

# Shell-скрипты всегда LF (обязательно для Docker/Linux)
*.sh text eol=lf

# PowerShell-скрипты — CRLF (Windows)
*.ps1 text eol=crlf

# Python — LF
*.py text eol=lf

# Бинарные файлы — без конвертации
*.mp3 binary
*.wav binary
*.mp4 binary
*.mkv binary
*.flac binary
*.png binary
*.jpg binary
